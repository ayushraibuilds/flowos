# FlowOS AI Backend Environment Configuration

# Gemini API Key (Required for AI endpoints)
GEMINI_API_KEY=your_google_ai_studio_key_here

# Supabase Authentication & Security Configuration (Required in production)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here
# Alternative secret key variable name:
# JWT_SECRET=your_jwt_secret_here

# Rate Limiting Controls (Format: count/second, count/minute, count/hour, or count/day)
RATE_LIMIT_DAILY_REPORT=5/minute
RATE_LIMIT_BREAK_SUGGESTION=10/minute
RATE_LIMIT_BRAIN_DUMP=10/minute
RATE_LIMIT_WEEKLY_REVIEW=5/minute
